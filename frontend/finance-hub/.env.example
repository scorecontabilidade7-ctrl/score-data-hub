# Projeto de autenticação (Supabase Auth)
VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key"
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"

# Projeto financeiro (dados eGestor / dados do cliente)
VITE_FINANCIAL_SUPABASE_URL="https://seu-projeto-financeiro.supabase.co"
VITE_FINANCIAL_SUPABASE_ANON_KEY="sua-anon-key-financeiro"

# Projeto RH (dados Sólides — opcional, apenas se usar módulo RH)
VITE_SOLIDES_SUPABASE_URL="https://seu-projeto-rh.supabase.co"
VITE_SOLIDES_SUPABASE_ANON_KEY="sua-anon-key-rh"
